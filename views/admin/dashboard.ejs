<%- include('../partials/header') %>

<div class="container mt-4">
  <h2>Admin Dashboard</h2>
  <div class="dashboard-stats" style="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
    
    <div class="stat-card" style="flex: 1; min-width: 200px; background: var(--light-color); padding: 20px; border-radius: 8px; box-shadow: var(--shadow); text-align: center;">
      <h3>Total Users</h3>
      <p style="font-size: 2rem; font-weight: bold; color: var(--primary-color);"><%= totalUsers %></p>
      <a href="/admin/users" class="btn" style="display: inline-block; margin-top: 10px; background: var(--accent-color); padding: 8px 15px; border-radius: 5px; color: var(--dark-color); text-decoration: none; font-weight: bold;">Manage Users</a>
    </div>

    <div class="stat-card" style="flex: 1; min-width: 200px; background: var(--light-color); padding: 20px; border-radius: 8px; box-shadow: var(--shadow); text-align: center;">
      <h3>Total Posts</h3>
      <p style="font-size: 2rem; font-weight: bold; color: var(--primary-color);"><%= totalPosts %></p>
      <a href="/" class="btn" style="display: inline-block; margin-top: 10px; background: var(--primary-color); padding: 8px 15px; border-radius: 5px; color: var(--light-color); text-decoration: none; font-weight: bold;">View Posts</a>
    </div>

    <div class="stat-card" style="flex: 1; min-width: 200px; background: var(--light-color); padding: 20px; border-radius: 8px; box-shadow: var(--shadow); text-align: center;">
      <h3>Total Comments</h3>
      <p style="font-size: 2rem; font-weight: bold; color: var(--primary-color);"><%= totalComments %></p>
    </div>

  </div>
</div>

<style>
  body.dark .stat-card {
    background: #2b2b3c !important;
    color: #e4e4e7;
  }
</style>

<%- include('../partials/footer') %>
