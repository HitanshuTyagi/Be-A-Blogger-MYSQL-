<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Be A Blogger</title>
  <style>
    /* --- Modern Theme Colors --- */
    :root {
      --primary-gradient: linear-gradient(135deg, #6a11cb, #2575fc);
      --primary-color: #2575fc;
      --accent-color: #ffb300;
      --light-color: #ffffff;
      --dark-color: #1a1a2e;
      --card-bg: #ffffff;
      --text-color: #333333;
      --border-color: #e2e8f0;
      --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.08);
      --input-bg: #f1f3f6;
      --input-text: #333;
    }

    /* Dark theme overrides */
    body.dark {
      --card-bg: #1a1a2e;
      --text-color: #e4e4e7;
      --border-color: #2b2b3c;
      --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.3);
      --input-bg: #2b2b3c;
      --input-text: #e4e4e7;
      background: #1e3a8a;
    }

    /* Global styles */
    * {
      box-sizing: border-box;
      transition: background-color 0.3s, color 0.3s, border-color 0.3s;
    }

    body {
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #1e3a8a;
      color: var(--text-color);
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* Header styles */
    .site-header {
      background: var(--primary-gradient);
      color: var(--light-color);
      padding: 15px 25px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .site-header .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      max-width: 1200px;
      margin: auto;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: bold;
      color: var(--accent-color);
      text-decoration: none;
      transition: 0.3s;
    }

    .logo:hover {
      color: #fff;
    }

    /* Search bar */
    .search {
      display: flex;
      flex: 1;
      max-width: 420px;
      margin: 10px 20px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      border-radius: 50px;
      overflow: hidden;
      background: var(--input-bg);
    }

    .search input {
      flex: 1;
      padding: 12px 18px;
      border: none;
      font-size: 15px;
      outline: none;
      background: var(--input-bg);
      color: var(--input-text);
    }

    .search button {
      padding: 0 22px;
      border: none;
      background: var(--accent-color);
      color: var(--dark-color);
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      border-radius: 0;
    }

    .search button:hover {
      background: #ffc947;
    }

    /* Navigation */
    nav {
      display: flex;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    nav a, nav button, nav form button {
      color: var(--light-color);
      text-decoration: none;
      font-size: 15px;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 8px 14px;
      border-radius: 6px;
      transition: 0.3s;
    }

    nav a:hover {
      background: rgba(255,255,255,0.15);
    }

    nav button, nav form button {
      background: var(--accent-color);
      color: var(--dark-color);
      font-weight: bold;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
    }

    nav button:hover, nav form button:hover {
      background: #ffc947;
    }

    nav a.login-register {
      background: var(--accent-color);
      color: var(--dark-color);
      font-weight: bold;
      padding: 8px 14px;
      border-radius: 6px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      transition: 0.3s;
    }

    nav a.login-register:hover {
      background: #ffc947;
    }

    /* Login page specific styles */
    .page-wrapper {
      min-height: calc(100vh - 140px);
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .login-container {
      background: var(--card-bg);
      padding: 40px 30px;
      border-radius: 16px;
      box-shadow: var(--shadow-soft);
      width: 100%;
      max-width: 350px;
      text-align: center;
      animation: fadeIn 0.8s ease-in-out;
      border: 1px solid var(--border-color);
    }

    .login-container h2 {
      margin-bottom: 25px;
      color: var(--primary-color);
      font-size: 26px;
      letter-spacing: 1px;
    }

    .login-container label {
      display: block;
      margin-bottom: 6px;
      color: var(--text-color);
      font-weight: 600;
      text-align: left;
    }

    .login-container input {
      width: 100%;
      padding: 12px;
      margin-bottom: 18px;
      border: 1px solid var(--border-color);
      border-radius: 10px;
      font-size: 15px;
      outline: none;
      transition: 0.3s;
      background: var(--input-bg);
      color: var(--input-text);
    }

    .login-container input:focus {
      border-color: var(--primary-color);
      box-shadow: 0 0 8px rgba(37, 117, 252, 0.3);
    }

    .login-container button {
      background: var(--primary-gradient);
      color: #fff;
      border: none;
      padding: 12px;
      width: 100%;
      border-radius: 10px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 6px 18px rgba(37, 117, 252, 0.4);
    }

    .login-container button:hover {
      background: linear-gradient(135deg, #2575fc, #6a11cb);
      box-shadow: 0 6px 20px rgba(37, 117, 252, 0.6);
    }

    .login-container p {
      margin-top: 15px;
      font-size: 14px;
      color: var(--text-color);
    }

    .login-container a {
      color: var(--primary-color);
      text-decoration: none;
      font-weight: 600;
    }

    .login-container a:hover {
      text-decoration: underline;
    }

    /* Flash messages */
    .flash {
      padding: 12px 18px;
      border-radius: 8px;
      margin: 15px 0;
      font-size: 15px;
      font-weight: 500;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      animation: fadeIn 0.4s ease;
    }
    
    .flash.success {
      background: #d4edda;
      color: #155724;
      border-left: 6px solid #28a745;
    }
    
    .flash.error {
      background: #f8d7da;
      color: #721c24;
      border-left: 6px solid #dc3545;
    }

    /* Responsive */
    @media (max-width: 700px) {
      .site-header .container {
        flex-direction: column;
        align-items: stretch;
      }
      
      nav {
        margin-top: 10px;
        justify-content: center;
      }
      
      .search {
        width: 100%;
        margin: 10px 0;
      }
      
      .login-container {
        width: 100%;
        max-width: 350px;
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Footer */
    footer {
      background: var(--dark-color);
      color: var(--light-color);
      text-align: center;
      padding: 20px;
      margin-top: auto;
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">Be A Blogger</a>



      <nav>
        <a href="/auth/login" class="login-register">Login</a>
        <a href="/auth/register" class="login-register">Register</a>
        <button id="themeToggle">🌙</button>
      </nav>
    </div>
  </header>

  <%- include('../partials/flash') %>

  <div class="page-wrapper">
    <div class="login-container">
      <h2>Welcome Back 👋</h2>
      <form action="/auth/login" method="post">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" placeholder="Enter your email" required />
        
        <label for="password">Password</label>
        <input id="password" name="password" type="password" placeholder="Enter your password" required />
        
        <button type="submit">Login</button>
      </form>
      <p>Don't have an account? <a href="/auth/register">Sign up</a></p>
    </div>
  </div>

  <footer>
    <p>&copy; 2023 Be A Blogger. All rights reserved.</p>
  </footer>

  <script>
    // Theme toggle functionality
    const toggleBtn = document.getElementById("themeToggle");
    const body = document.body;
    
    // Check for saved theme preference or respect OS preference
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    
    // Set initial theme
    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      body.classList.add('dark');
      toggleBtn.textContent = '☀️';
    } else {
      body.classList.remove('dark');
      toggleBtn.textContent = '🌙';
    }
    
    // Toggle theme on button click
    toggleBtn.addEventListener("click", () => {
      body.classList.toggle("dark");
      const isDark = body.classList.contains("dark");
      toggleBtn.textContent = isDark ? "☀️" : "🌙";
      
      // Save preference to localStorage
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
</body>
</html>