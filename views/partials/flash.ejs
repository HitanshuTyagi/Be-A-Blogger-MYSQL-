<% if (success && success.length > 0) { %>
  <div id="flash-message" class="flash-popup success">
    <%= success %>
  </div>
<% } %>

<% if (error && error.length > 0) { %>
  <div id="flash-message" class="flash-popup error">
    <%= error %>
  </div>
<% } %>

<style>
  .flash-popup {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 2000;
    padding: 15px 20px;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    font-weight: 500;
    animation: fadeIn 0.4s ease;
  }
  .flash-popup.success {
    background: #d4edda;
    color: #155724;
    border-left: 6px solid #28a745;
  }
  .flash-popup.error {
    background: #f8d7da;
    color: #721c24;
    border-left: 6px solid #dc3545;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  setTimeout(() => {
    const flash = document.getElementById("flash-message");
    if (flash) flash.remove();
  }, 4000);
</script>
