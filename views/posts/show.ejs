<%- include('../partials/header') %>

<main class="post-container">
  <article class="post-full">
    <header class="post-header">
      <div class="category-badge">Technology</div>
      <h1 class="post-title"><%= post.title %></h1>
      
      <div class="post-meta">
        <div class="author-info">
          <div class="avatar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="author-name">By <%= post.author.username %></p>
            <p class="post-date"><%= post.createdAt.toDateString() %></p>
          </div>
        </div>
        
        <div class="meta-stats">
          <div class="stat">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
            </svg>
            <span id="likesCount"><%= post.likes.length %></span>
          </div>
          <div class="stat">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path fill-rule="evenodd" d="M4.804 21.644A6.707 6.707 0 006 21.75a6.721 6.721 0 003.583-1.029c.774.182 1.584.279 2.417.279 5.322 0 9.75-3.97 9.75-9 0-5.03-4.428-9-9.75-9s-9.75 3.97-9.75 9c0 2.409 1.025 4.587 2.674 6.192.232.226.277.428.254.543a3.73 3.73 0 01-.814 1.686.75.75 0 00.44 1.223zM8.25 10.875a1.125 1.125 0 100 2.25 1.125 1.125 0 000-2.25zM10.875 12a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0zm4.875-1.125a1.125 1.125 0 100 2.25 1.125 1.125 0 000-2.25z" clip-rule="evenodd" />
            </svg>
            <span><%= comments.length %></span>
          </div>
          <div class="stat">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path fill-rule="evenodd" d="M7.5 5.25a3 3 0 013-3h3a3 3 0 013 3v.205c.933.085 1.857.197 2.774.334 1.454.218 2.476 1.483 2.476 2.917v3.033c0 1.211-.734 2.352-1.936 2.752A24.726 24.726 0 0112 15.75c-2.73 0-5.357-.442-7.814-1.259-1.202-.4-1.936-1.541-1.936-2.752V8.706c0-1.434 1.022-2.7 2.476-2.917A48.814 48.814 0 017.5 5.455V5.25zm7.5 0v.09a49.488 49.488 0 00-6 0v-.09a1.5 1.5 0 011.5-1.5h3a1.5 1.5 0 011.5 1.5zm-3 8.25a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd" />
            </svg>
            <span>5 min read</span>
          </div>
        </div>
      </div>
    </header>

    <% if (post.image) { %>
      <div class="post-image-container">
        <img src="<%= post.image %>" alt="Post image" class="post-image"/>
        <% if (post.imageCaption) { %>
          <figcaption class="image-caption"><%= post.imageCaption %></figcaption>
        <% } %>
      </div>
    <% } %>

    <div class="post-content"><%= post.content %></div>

    <footer class="post-footer">
      <div class="post-tags">
        <% post.tags.forEach(tag => { %>
          <span class="tag"><%= tag %></span>
        <% }) %>
      </div>

      <div class="post-actions">
  <% if (currentUser) { %>
    <button class="like-btn <%= post.likes.includes(currentUser.id) ? 'liked' : '' %>" data-post-id="<%= post.id %>">
      <span class="heart-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
        </svg>
      </span>
      <span class="btn-text"><%= post.likes.includes(currentUser.id) ? 'Liked' : 'Like' %></span>
    </button>
    
    <% if (currentUser.id === post.authorId || currentUser.role === 'admin') { %>
      <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to delete this post?');">
        <button type="submit" class="like-btn" style="color: #dc3545; border-color: #dc3545; margin-left:10px;">
          <span class="btn-text">Delete Post</span>
        </button>
      </form>
    <% } %>
  <% } %>
</div>

    </footer>

    <section class="comments-section">
      <div class="section-header">
        <h2>Comments</h2>
        <span class="comments-count"><%= comments.length %> <%= comments.length === 1 ? 'Comment' : 'Comments' %></span>
      </div>

      <form action="/posts/<%= post.slug %>/comments" method="post" class="comment-form">
        <% if (!currentUser) { %>
          <input name="name" placeholder="Your name" class="form-input"/>
        <% } %>
        <textarea name="text" placeholder="Write a comment..." required class="form-textarea"></textarea>
        <button class="btn-primary">
          <span>Post Comment</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" />
          </svg>
        </button>
      </form>

      <div class="comments">
        <% comments.forEach(c => { %>
          <div class="comment-card">
            <div class="comment-avatar">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="comment-content">
              <div class="comment-header">
                <strong><%= c.authorName %></strong>
                <small><%= c.createdAt.toLocaleString() %></small>
              </div>
              <p><%= c.text %></p>
              <div class="comment-actions">
                <button class="reply-btn">Reply</button>
                <button class="like-btn">Like</button>
                
                <% if (currentUser && (currentUser.id === c.authorId || currentUser.role === 'admin')) { %>
                  <form action="/posts/<%= post.slug %>/comments/<%= c.id %>?_method=DELETE" method="POST" style="margin: 0; display: inline;" onsubmit="return confirm('Are you sure you want to delete this comment?');">
                    <button type="submit" class="reply-btn" style="color: #dc3545;">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </article>
</main>

<script>
  // Like button functionality
  document.querySelectorAll('.like-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const postId = btn.dataset.postId;

      try {
        const res = await fetch(`/posts/${postId}/like`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include' // send session cookie
        });

        const data = await res.json();

        if (data.ok) {
          // Toggle liked class and text
          btn.classList.toggle('liked');
          btn.querySelector('.btn-text').textContent = btn.classList.contains('liked') ? 'Liked' : 'Like';
          
          // Update like count in the stats section
          const likesCountEl = document.getElementById('likesCount');
          if (likesCountEl) likesCountEl.textContent = data.likes;

          // Add heartbeat animation
          if (btn.classList.contains('liked')) {
            const heart = btn.querySelector('.heart-icon svg');
            heart.style.animation = 'heartBeat 0.5s ease-in-out';
            heart.addEventListener('animationend', () => {
              heart.style.animation = '';
            });
          }
        } else {
          alert(data.error || 'Could not like the post');
        }
      } catch (err) {
        console.error(err);
        alert('Server error');
      }
    });
  });
</script>



<%- include('../partials/footer') %>

<style>
  /* --- Modern Theme Colors with Dark Mode Support --- */
  :root {
    --primary-gradient: linear-gradient(135deg, #6a11cb, #2575fc);
    --primary: #7c3aed;
    --primary-light: #8b5cf6;
    --primary-dark: #6d28d9;
    --secondary: #ec4899;
    --accent: #ffb300;
    --text: #1f2937;
    --text-light: #6b7280;
    --bg: #ffffff;
    --bg-secondary: #f9fafb;
    --border: #e5e7eb;
    --shadow: rgba(0, 0, 0, 0.05);
    --card-bg: #ffffff;
    --tag-bg: #f3f4f6;
    --success: #10b981;
    --input-bg: #f1f3f6;
    --input-text: #333;
  }

  [data-theme="dark"] {
    --text: #f9fafb;
    --text-light: #d1d5db;
    --bg: #111827;
    --bg-secondary: #1f2937;
    --border: #374151;
    --shadow: rgba(0, 0, 0, 0.2);
    --card-bg: #1a1a2e;
    --tag-bg: #374151;
    --input-bg: #2b2b3c;
    --input-text: #e4e4e7;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    transition: background-color 0.3s, color 0.3s, border-color 0.3s;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", sans-serif;
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.6;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .post-container {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }

  .post-full {
    background: var(--card-bg);
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 0 10px 35px var(--shadow);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .post-full::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: var(--primary-gradient);
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .category-badge {
    display: inline-block;
    background: var(--primary-gradient);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .post-title {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: var(--text);
    transition: color 0.3s ease;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--primary-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .avatar svg {
    width: 26px;
    height: 26px;
  }

  .author-name {
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
    font-size: 1.1rem;
  }

  .post-date {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  .meta-stats {
    display: flex;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-light);
    font-weight: 500;
  }

  .stat svg {
    width: 20px;
    height: 20px;
    color: var(--primary);
  }

  .post-image-container {
    margin: 2.5rem 0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 15px 30px var(--shadow);
    transition: transform 0.3s ease;
  }

  .post-image-container:hover {
    transform: translateY(-5px);
  }

  .post-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .post-image:hover {
    transform: scale(1.03);
  }

  .image-caption {
    text-align: center;
    font-style: italic;
    color: var(--text-light);
    padding: 1rem;
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }

  .post-content {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2.5rem;
  }

  .post-content p {
    margin-bottom: 1.8rem;
  }

  .post-content h2, 
  .post-content h3 {
    margin-top: 2.8rem;
    margin-bottom: 1.2rem;
    color: var(--text);
    font-weight: 700;
  }

  .post-content h2 {
    font-size: 1.8rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .post-content blockquote {
    border-left: 4px solid var(--primary);
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    font-style: italic;
    color: var(--text-light);
    background: var(--bg-secondary);
    border-radius: 0 12px 12px 0;
  }

  .post-content a {
    color: var(--primary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.3s ease;
    font-weight: 600;
  }

  .post-content a:hover {
    border-bottom-color: var(--primary);
  }

  .post-footer {
    margin: 3rem 0;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--text);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 1px solid var(--border);
  }

  .tag:hover {
    background: var(--primary);
    color: white;
    cursor: pointer;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  .post-actions {
    display: flex;
    justify-content: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg-secondary);
    border: 2px solid var(--border);
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px var(--shadow);
  }

  .like-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .like-btn.liked {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .heart-icon svg {
    width: 22px;
    height: 22px;
    transition: transform 0.3s ease;
  }

  .like-btn:hover .heart-icon svg {
    transform: scale(1.2);
  }

  .comments-section {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    color: var(--text);
    font-size: 1.8rem;
    font-weight: 700;
  }

  .comments-count {
    color: var(--text-light);
    font-size: 1rem;
    font-weight: 500;
  }

  .comment-form {
    margin-bottom: 2.5rem;
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: 16px;
    box-shadow: 0 5px 15px var(--shadow);
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    border: 2px solid var(--border);
    background: var(--input-bg);
    color: var(--input-text);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s ease;
    margin-bottom: 1.2rem;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary-gradient);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--primary-dark), var(--secondary));
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .btn-primary svg {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .comments {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .comment-card {
    display: flex;
    gap: 1.2rem;
    padding: 2rem;
    background: var(--bg-secondary);
    border-radius: 16px;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px var(--shadow);
  }

  .comment-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px var(--shadow);
  }

  .comment-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--tag-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-light);
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .comment-avatar svg {
    width: 24px;
    height: 24px;
  }

  .comment-content {
    flex: 1;
  }

  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .comment-header strong {
    color: var(--text);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .comment-header small {
    color: var(--text-light);
    font-size: 0.85rem;
  }

  .comment-content p {
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .comment-actions {
    display: flex;
    gap: 1.2rem;
  }

  .reply-btn,
  .comment-actions .like-btn {
    background: none;
    border: none;
    color: var(--text-light);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .reply-btn:hover,
  .comment-actions .like-btn:hover {
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .post-container {
      padding: 0 1rem;
    }
    
    .post-full {
      padding: 2rem 1.5rem;
    }
    
    .post-title {
      font-size: 2.2rem;
    }
    
    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
    }
    
    .meta-stats {
      width: 100%;
      justify-content: space-between;
    }
    
    .comment-card {
      flex-direction: column;
      text-align: center;
    }
    
    .comment-header {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .comment-actions {
      justify-content: center;
    }
  }

  /* Animation for like button */
  @keyframes heartBeat {
    0% { transform: scale(1); }
    25% { transform: scale(1.3); }
    50% { transform: scale(1); }
    75% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  .like-btn.liked .heart-icon svg {
    animation: heartBeat 0.5s ease-in-out;
  }
</style>