<%- include('../partials/header') %>

<div class="profile-page">
  <div class="profile-header">
    <div class="profile-avatar">
      <% if (user.profileImage) { %>
        <img src="<%= user.profileImage %>" alt="Profile Avatar" class="avatar-img">
      <% } else { %>
        <div class="avatar-placeholder">
          <i class="fas fa-user"></i>
        </div>
      <% } %>
    </div>
    <h2 class="profile-title">Your Profile</h2>
    <p class="profile-subtitle">Manage your information and view your posts</p>
  </div>

  <div class="profile-content">
    <form action="/users/profile" method="post" enctype="multipart/form-data" class="profile-form">
      <div class="form-card">
        <h3 class="form-section-title">Personal Information</h3>
        
        <div class="form-group">
          <label for="bio" class="form-label">Bio</label>
          <textarea id="bio" name="bio" class="form-textarea" placeholder="Tell something about yourself..."><%= user.bio || '' %></textarea>
          <div class="char-count" id="bio-char-count">0/250 characters</div>
        </div>

        <div class="form-group">
          <label for="profileImage" class="form-label">Profile Image</label>
          <div class="file-upload-container">
            <div class="file-upload" id="fileUploadArea">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>Drag & drop your image or <strong>browse</strong></p>
              <span>JPG, PNG, GIF up to 5MB</span>
              <input id="profileImage" type="file" name="profileImage" accept="image/*" class="file-input" />
            </div>
            <div class="file-name" id="file-name">No file selected</div>
          </div>
        </div>

        <button class="btn btn-primary btn-update">
          <i class="fas fa-save"></i> Update Profile
        </button>
      </div>
    </form>

    <div class="user-posts-card">
      <div class="posts-header">
        <h3 class="posts-title">Your Posts</h3>
        <div class="posts-search">
          <i class="fas fa-search"></i>
          <input type="text" id="posts-search" placeholder="Search your posts...">
        </div>
      </div>
      
      <% if (posts.length > 0) { %>
        <ul class="posts-list">
          <% posts.forEach(p => { %>
            <li class="post-item" data-title="<%= p.title.toLowerCase() %>">
              <div class="post-content">
                <a href="/posts/<%= p.slug %>" class="post-link"><%= p.title %></a>
                <div class="post-meta">
                  <span class="post-date"><i class="far fa-calendar"></i> <%= new Date(p.createdAt).toLocaleDateString() %></span>
                  <span class="post-comments"><i class="far fa-comment"></i> <%= p.comments ? p.comments.length : 0 %></span>
                </div>
              </div>
              <div class="post-actions">
                <a href="/posts/<%= p.id %>/edit" class="btn-icon" title="Edit Post">
                  <i class="fas fa-edit"></i>
                </a>
              </div>
            </li>
          <% }) %>
        </ul>
        
        <div class="no-posts-found" style="display: none;">
          <i class="fas fa-search"></i>
          <p>No posts match your search</p>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-file-alt"></i>
          <p>You haven't created any posts yet</p>
          <a href="/posts/new" class="btn btn-outline">Create Your First Post</a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<style>
  /* --- Modern Theme Colors --- */
  :root {
    --primary-gradient: linear-gradient(135deg, #6a11cb, #2575fc);
    --primary-color: #2575fc;
    --accent-color: #ffb300;
    --light-color: #ffffff;
    --dark-color: #1a1a2e;
    --card-bg: #ffffff;
    --text-color: #333333;
    --border-color: #e2e8f0;
    --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.08);
    --input-bg: #f1f3f6;
    --input-text: #333;
  }

  /* Dark theme overrides */
  body.dark {
    --card-bg: #1a1a2e;
    --text-color: #e4e4e7;
    --border-color: #2b2b3c;
    --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.3);
    --input-bg: #2b2b3c;
    --input-text: #e4e4e7;
    background: #1e3a8a;
  }

  /* Global styles */
  * {
    box-sizing: border-box;
    transition: background-color 0.3s, color 0.3s, border-color 0.3s;
  }

  body {
    margin: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #1e3a8a;
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .profile-page {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .profile-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .profile-avatar {
    margin-bottom: 20px;
  }

  .avatar-img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--card-bg);
    box-shadow: var(--shadow-soft);
  }

  .avatar-placeholder {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--primary-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    color: white;
    font-size: 40px;
  }

  .profile-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text-color);
  }

  .profile-subtitle {
    font-size: 16px;
    color: var(--text-color);
    opacity: 0.8;
    margin-bottom: 0;
  }

  .profile-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .form-card, .user-posts-card {
    background: var(--card-bg);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
    padding: 30px;
    border: 1px solid var(--border-color);
  }

  .form-section-title, .posts-title {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 24px;
    color: var(--text-color);
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-color);
  }

  .form-textarea {
    width: 100%;
    min-height: 120px;
    padding: 14px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    font-family: inherit;
    font-size: 15px;
    resize: vertical;
    transition: 0.3s;
    background-color: var(--input-bg);
    color: var(--input-text);
  }

  .form-textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 8px rgba(37, 117, 252, 0.3);
  }

  .char-count {
    text-align: right;
    font-size: 12px;
    color: var(--text-color);
    opacity: 0.7;
    margin-top: 4px;
  }

  /* File upload */
  .file-upload {
    border: 2px dashed var(--border-color);
    border-radius: 10px;
    padding: 25px;
    text-align: center;
    margin-bottom: 10px;
    cursor: pointer;
    transition: 0.3s;
    background: var(--input-bg);
    position: relative;
  }

  .file-upload:hover {
    border-color: var(--primary-color);
  }

  .file-upload i {
    font-size: 40px;
    color: var(--primary-color);
    margin-bottom: 10px;
  }

  .file-upload p {
    margin: 5px 0;
    color: var(--text-color);
  }

  .file-upload span {
    font-size: 13px;
    color: var(--text-color);
    opacity: 0.8;
  }

  .file-input {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .file-name {
    font-size: 14px;
    color: var(--text-color);
    opacity: 0.8;
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
    border: none;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    box-shadow: 0 6px 18px rgba(37, 117, 252, 0.4);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #2575fc, #6a11cb);
    box-shadow: 0 6px 20px rgba(37, 117, 252, 0.6);
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--primary-color);
    color: var(--primary-color);
  }

  .btn-outline:hover {
    background: var(--primary-color);
    color: white;
  }

  .btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--input-bg);
    color: var(--text-color);
    transition: 0.3s;
  }

  .btn-icon:hover {
    background: var(--primary-color);
    color: white;
  }

  /* Posts section */
  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 15px;
  }

  .posts-search {
    position: relative;
    display: flex;
    align-items: center;
  }

  .posts-search i {
    position: absolute;
    left: 12px;
    color: var(--text-color);
    opacity: 0.7;
    z-index: 1;
  }

  #posts-search {
    padding: 10px 15px 10px 40px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--input-bg);
    color: var(--input-text);
    width: 250px;
    transition: 0.3s;
  }

  #posts-search:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 8px rgba(37, 117, 252, 0.3);
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
    transition: 0.3s;
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item:hover {
    background: var(--input-bg);
    border-radius: 10px;
  }

  .post-content {
    flex: 1;
  }

  .post-link {
    text-decoration: none;
    color: var(--text-color);
    font-weight: 600;
    font-size: 17px;
    transition: 0.3s;
    display: block;
    margin-bottom: 8px;
  }

  .post-link:hover {
    color: var(--primary-color);
  }

  .post-meta {
    display: flex;
    gap: 15px;
    font-size: 13px;
    color: var(--text-color);
    opacity: 0.8;
  }

  .post-meta i {
    margin-right: 5px;
  }

  .post-date, .post-comments {
    display: flex;
    align-items: center;
  }

  .no-posts-found {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-color);
    opacity: 0.7;
  }

  .no-posts-found i {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-color);
    opacity: 0.7;
  }

  .empty-state i {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-state p {
    margin-bottom: 20px;
  }

  /* Theme toggle button */
  .theme-toggle {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    z-index: 100;
    transition: 0.3s;
  }

  .theme-toggle:hover {
    transform: rotate(30deg);
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .profile-page {
    animation: fadeIn 0.5s ease-out;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .profile-page {
      padding: 0 15px;
    }
    
    .form-card, .user-posts-card {
      padding: 20px;
    }
    
    .posts-header {
      flex-direction: column;
      align-items: stretch;
    }
    
    #posts-search {
      width: 100%;
    }
    
    .post-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
    
    .post-actions {
      align-self: flex-end;
    }
    
    .post-meta {
      flex-wrap: wrap;
      gap: 10px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Bio character counter
    const bioTextarea = document.getElementById('bio');
    const charCount = document.getElementById('bio-char-count');
    
    if (bioTextarea && charCount) {
      // Set initial count
      charCount.textContent = `${bioTextarea.value.length}/250 characters`;
      
      // Update on input
      bioTextarea.addEventListener('input', function() {
        charCount.textContent = `${this.value.length}/250 characters`;
      });
    }
    
    // File input display
    const fileInput = document.getElementById('profileImage');
    const fileName = document.getElementById('file-name');
    const fileUploadArea = document.getElementById('fileUploadArea');
    
    if (fileInput && fileName && fileUploadArea) {
      // Drag and drop functionality
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        fileUploadArea.addEventListener(eventName, preventDefaults, false);
      });
      
      function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
      }
      
      ['dragenter', 'dragover'].forEach(eventName => {
        fileUploadArea.addEventListener(eventName, highlight, false);
      });
      
      ['dragleave', 'drop'].forEach(eventName => {
        fileUploadArea.addEventListener(eventName, unhighlight, false);
      });
      
      function highlight() {
        fileUploadArea.style.borderColor = 'var(--primary-color)';
        fileUploadArea.style.backgroundColor = 'rgba(37, 117, 252, 0.1)';
      }
      
      function unhighlight() {
        fileUploadArea.style.borderColor = 'var(--border-color)';
        fileUploadArea.style.backgroundColor = 'var(--input-bg)';
      }
      
      fileUploadArea.addEventListener('drop', handleDrop, false);
      
      function handleDrop(e) {
        const dt = e.dataTransfer;
        const files = dt.files;
        fileInput.files = files;
        handleFiles(files);
      }
      
      fileInput.addEventListener('change', function() {
        handleFiles(this.files);
      });
      
      function handleFiles(files) {
        if (files.length > 0) {
          fileName.textContent = files[0].name;
        } else {
          fileName.textContent = 'No file selected';
        }
      }
    }
    
    // Posts search functionality
    const postsSearch = document.getElementById('posts-search');
    const postItems = document.querySelectorAll('.post-item');
    const noPostsFound = document.querySelector('.no-posts-found');
    
    if (postsSearch && postItems.length > 0) {
      postsSearch.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        let visibleCount = 0;
        
        postItems.forEach(item => {
          const title = item.getAttribute('data-title');
          if (title.includes(searchTerm)) {
            item.style.display = 'flex';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });
        
        // Show/hide no results message
        if (noPostsFound) {
          if (visibleCount === 0 && searchTerm !== '') {
            noPostsFound.style.display = 'block';
          } else {
            noPostsFound.style.display = 'none';
          }
        }
      });
    }
    
    // Theme toggle functionality
    const themeToggle = document.createElement('button');
    themeToggle.className = 'theme-toggle';
    themeToggle.innerHTML = '🌙';
    themeToggle.setAttribute('aria-label', 'Toggle dark mode');
    document.body.appendChild(themeToggle);
    
    // Check for saved theme preference or respect OS preference
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    
    // Set initial theme
    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      document.body.classList.add('dark');
      themeToggle.textContent = '☀️';
    } else {
      document.body.classList.remove('dark');
      themeToggle.textContent = '🌙';
    }
    
    // Toggle theme on button click
    themeToggle.addEventListener('click', () => {
      document.body.classList.toggle('dark');
      const isDark = document.body.classList.contains('dark');
      themeToggle.textContent = isDark ? '☀️' : '🌙';
      
      // Save preference to localStorage
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  });
</script>